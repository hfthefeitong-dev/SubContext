{
  "manifest_version": 3,
  "name": "字幕上下文翻译先锋版",
  "version": "1.1.0",
  "description": "实时抓取字幕（Spotify等）并结合上下文翻译为中文的扩展。",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://api.openai.com/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://open.spotify.com/*",
        "https://m.youtube.com/*",
        "https://www.youtube.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "字幕上下文翻译",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "options_page": "options.html"
}
